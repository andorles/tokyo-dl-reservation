# Copy this file to `.env.local` and fill in real values. `.env.local`
# is gitignored — never commit credentials.

# --- SMTP (notifier) ---
# Generate the Gmail app-specific password at:
#   https://myaccount.google.com/apppasswords
# (You need 2-Step Verification enabled to access this page.)
DL_RES_SMTP_HOST=smtp.gmail.com
DL_RES_SMTP_PORT=465
DL_RES_SMTP_USER=your.email@gmail.com
DL_RES_SMTP_PASSWORD=__paste_app_password_here__
DL_RES_EMAIL_FROM=your.email@gmail.com
DL_RES_EMAIL_TO=your.email@gmail.com

# --- Booker (v1 — only needed if running with --enable-booker) ---
# Per ADR-7. All 4 must be set together; missing any one disables the booker.
#
# NAME: fullwidth Latin OR fullwidth Katakana — same form the SPA shows in
#       the booking confirmation page. e.g. ＹＡＭＡＤＡタロウ or ＴＡＲＯ ＹＡＭＡＤＡ
# BIRTHDAY: YYYYMMDD half-width digits
# PHONE: 11 half-width digits, no dashes
# GRACER_NO (仮免許番号): half-width digits — booker.py auto-converts to
#                        fullwidth on POST
DL_RES_BOOKER_NAME=__paste_fullwidth_name_here__
DL_RES_BOOKER_BIRTHDAY=__YYYYMMDD__
DL_RES_BOOKER_PHONE=__11_digit_phone__
DL_RES_BOOKER_GRACER_NO=__juken_number__
